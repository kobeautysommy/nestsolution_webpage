{
  "rewrites": [
    {
      "source": "/blog",
      "destination": "https://nestsolu.jp4.fcomet.com/blog"
    },
    {
      "source": "/blog/:path*",
      "destination": "https://nestsolu.jp4.fcomet.com/blog/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
